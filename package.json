{
  "name": "vue-3-ts-vite-boilerplate",
  "version": "2.0.1",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "oh-vue-icons": "^1.0.0-rc3",
    "pinia": "^2.1.7",
    "vue": "^3.4.29",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.0.0",
    "msw": "^2.14.6",
    "prettier": "^3.0.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.6",
    "vitest": "^3.2.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:all": "eslint src __tests__ --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "format:all": "prettier --write \"src/**/*.{ts,vue,css}\" \"__tests__/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
